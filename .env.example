# Database
DATABASE_URL=postgresql://smm_user:smm_password@localhost:5432/smm_panel
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smm_panel
DB_USER=smm_user
DB_PASSWORD=smm_password

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Payment Gateways
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_test_

PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret

# Email
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.your_api_key
EMAIL_FROM=noreply@smmpanel.com

# SMM Provider
SMM_PROVIDER_API_KEY=your_smm_provider_key
SMM_PROVIDER_URL=https://api.provider.com

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Security
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:3000
